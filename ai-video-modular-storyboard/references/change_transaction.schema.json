{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/ai-video-modular-storyboard/change_transaction.schema.json",
  "title": "Storyboard Change Transaction",
  "type": "object",
  "required": [
    "contract_version", "artifact_id", "owner_skill", "version", "sha256", "approval_status",
    "dependencies", "affected_shot_uids", "stale_reason", "transaction_id",
    "mode", "status", "requested_shot_uids", "atomic_commit", "route_to_shot_contract"
  ],
  "properties": {
    "contract_version": {"const": "ai-video-artifact-v1"},
    "artifact_id": {"type": "string", "minLength": 1},
    "owner_skill": {"const": "ai-video-modular-storyboard"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "approval_status": {"enum": ["draft", "assistant_validated", "user_approved", "stale", "blocked"]},
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "owner_skill", "version", "sha256"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "owner_skill": {"type": "string", "minLength": 1},
          "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "affected_shot_uids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "stale_reason": {"type": ["string", "null"]},
    "transaction_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["replace_frames", "reorder_request"]},
    "status": {"enum": ["staging", "pending_review", "applied", "rejected", "routed_upstream"]},
    "requested_shot_uids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "atomic_commit": {"type": "boolean"},
    "route_to_shot_contract": {"type": "boolean"},
    "base_manifest_path": {"type": "string", "minLength": 1},
    "base_manifest_file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "base_manifest_ref": {"$ref": "#/$defs/artifactRef"},
    "old_frames": {"type": "array", "items": {"$ref": "#/$defs/frameLock"}},
    "new_frames": {"type": "array", "items": {"$ref": "#/$defs/frameLock"}},
    "unaffected_hash_assertions": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "downstream_invalidations": {"type": "array"}
  },
  "$defs": {
    "artifactRef": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "owner_skill", "version", "sha256"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "owner_skill": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "frameLock": {
      "type": "object", "additionalProperties": false,
      "required": ["shot_uid", "artifact_id", "version", "sha256", "file_sha256"],
      "properties": {
        "shot_uid": {"type": "string", "minLength": 1},
        "artifact_id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"mode": {"const": "replace_frames"}, "status": {"const": "applied"}}, "required": ["mode", "status"]},
      "then": {"required": ["base_manifest_path", "base_manifest_file_sha256", "base_manifest_ref", "old_frames", "new_frames", "unaffected_hash_assertions", "downstream_invalidations"]}
    }
  ],
  "additionalProperties": false
}
