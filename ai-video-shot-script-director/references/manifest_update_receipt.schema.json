{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-video-manifest-update-receipt.schema.json",
  "title": "AI Video Project Canon Manifest Update Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "canonical_manifest_locator", "updated_by_skill", "base_manifest_sha256",
    "resulting_manifest_sha256", "registered_artifact_ids", "delta_status"
  ],
  "properties": {
    "schema_version": {"const": "ai-video-manifest-update-receipt.v1"},
    "canonical_manifest_locator": {"const": "00_project_canon/PROJECT_CANON_MANIFEST.json"},
    "updated_by_skill": {"type": "string", "minLength": 1},
    "base_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "resulting_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "registered_artifact_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "delta_status": {"const": "applied"}
  }
}
