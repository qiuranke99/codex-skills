{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-video-workflow-canon-pending-transaction.schema.json",
  "title": "AI Video Workflow Canon Pending Transaction Journal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "status", "updated_by_skill", "transaction_id",
    "package_root_locator", "base_snapshot_locator", "candidate_post_locator",
    "candidate_post_file_sha256", "receipt_locator", "base_manifest_sha256",
    "resulting_manifest_sha256", "registered_artifact_ids",
    "preserved_artifact_ids", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "ai-video-workflow-canon-pending-transaction.v1"},
    "status": {"const": "prepared_or_committed_receipt_pending"},
    "updated_by_skill": {
      "enum": [
        "ai-video-shot-script-director", "ai-video-global-look-lock",
        "ai-video-modular-storyboard",
        "ai-video-timed-animatic-previs-director",
        "ai-video-keyframe-continuity-pack",
        "ai-video-omni-reference-prompt-director"
      ]
    },
    "transaction_id": {"type": "string", "minLength": 1},
    "package_root_locator": {"$ref": "#/$defs/safeLocator"},
    "base_snapshot_locator": {"$ref": "#/$defs/safeLocator"},
    "candidate_post_locator": {"$ref": "#/$defs/safeLocator"},
    "candidate_post_file_sha256": {"$ref": "#/$defs/sha"},
    "receipt_locator": {"$ref": "#/$defs/safeLocator"},
    "base_manifest_sha256": {"$ref": "#/$defs/sha"},
    "resulting_manifest_sha256": {"$ref": "#/$defs/sha"},
    "registered_artifact_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "preserved_artifact_ids": {
      "type": "array", "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "safeLocator": {
      "type": "string", "minLength": 1,
      "not": {"pattern": "(^/|^[A-Za-z]:|\\\\|(^|/)\\.\\.(/|$))"}
    }
  }
}
