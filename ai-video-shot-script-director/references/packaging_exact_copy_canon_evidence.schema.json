{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "packaging_exact_copy_canon_evidence.schema.json",
  "title": "Packaging Asset-Board Canon Authority Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "owner_skill", "asset_key", "primary_asset_sha256",
    "packaging_run", "validator_file_sha256", "final_board", "sha256"
  ],
  "properties": {
    "schema_version": {"const": "packaging-board-canon-evidence.v1"},
    "owner_skill": {"const": "packaging-product-identity-label-lock-board"},
    "asset_key": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"},
    "primary_asset_sha256": {"$ref": "#/$defs/sha"},
    "packaging_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_root_locator", "asset_board_manifest_locator", "asset_board_manifest_file_sha256"
      ],
      "properties": {
        "run_root_locator": {"$ref": "#/$defs/safeLocator"},
        "asset_board_manifest_locator": {"$ref": "#/$defs/safeLocator"},
        "asset_board_manifest_file_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "validator_file_sha256": {"$ref": "#/$defs/sha"},
    "final_board": {"$ref": "#/$defs/fileLock"},
    "sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "safeLocator": {
      "type": "string",
      "minLength": 1,
      "not": {"pattern": "(^/|(^|/)\\.\\.(/|$))"}
    },
    "fileLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locator", "file_sha256"],
      "properties": {
        "locator": {"$ref": "#/$defs/safeLocator"},
        "file_sha256": {"$ref": "#/$defs/sha"}
      }
    }
  }
}
