{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-video-shot-contract.schema.json",
  "title": "AI Video Professional Shot Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_version",
    "artifact_id",
    "owner_skill",
    "version",
    "sha256",
    "approval_status",
    "dependencies",
    "affected_shot_uids",
    "stale_reason",
    "project_id",
    "source_inputs",
    "source_classification",
    "director_intent",
    "production_spec",
    "global_directing_grammar",
    "global_directing_prompt_full",
    "timeline",
    "shots",
    "continuity_map",
    "asset_requirement_map",
    "keyframe_requirement_map",
    "previs_requirement_map",
    "inferred_directing_decisions",
    "claim_boundary",
    "isolated_blockers",
    "revision_scope"
  ],
  "properties": {
    "schema_version": {"const": "ai-video-shot-contract.v1"},
    "contract_version": {"const": "ai-video-artifact-v1"},
    "artifact_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]+$"},
    "owner_skill": {"const": "ai-video-shot-script-director"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "sha256": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      ]
    },
    "approval_status": {"enum": ["draft", "assistant_validated", "user_approved", "stale", "blocked"]},
    "dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependency"}},
    "affected_shot_uids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/shotUid"}},
    "stale_reason": {"type": ["string", "null"]},
    "project_id": {"type": "string", "minLength": 1},
    "source_inputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/sourceInput"}},
    "source_classification": {"$ref": "#/$defs/sourceClassification"},
    "director_intent": {"type": "string", "minLength": 10},
    "production_spec": {"$ref": "#/$defs/productionSpec"},
    "global_directing_grammar": {"$ref": "#/$defs/directingGrammar"},
    "global_directing_prompt_full": {"type": "string", "minLength": 40},
    "timeline": {"$ref": "#/$defs/timeline"},
    "shots": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/shot"}},
    "continuity_map": {"type": "array", "items": {"$ref": "#/$defs/continuityEdge"}},
    "asset_requirement_map": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/assetRequirement"}},
    "keyframe_requirement_map": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/keyframeRequirement"}},
    "previs_requirement_map": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/previsRequirement"}},
    "inferred_directing_decisions": {"type": "array", "items": {"$ref": "#/$defs/inference"}},
    "claim_boundary": {"$ref": "#/$defs/claimBoundary"},
    "isolated_blockers": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/isolatedBlocker"}},
    "revision_scope": {"$ref": "#/$defs/revisionScope"}
  },
  "$defs": {
    "shotUid": {"type": "string", "pattern": "^[A-Z][A-Z0-9_-]*[0-9][A-Z0-9_-]*$"},
    "nonEmptyStrings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "owner_skill", "version", "sha256"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "owner_skill": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "sourceClassification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "creative_mode", "primary_mode", "narrative_logic", "product_expression", "literal_usage_demo", "source_intent_preserved"],
      "properties": {
        "source_type": {"enum": ["rough_idea", "partial_shot_list", "structured_creative_shot_draft", "professional_script_revision"]},
        "creative_mode": {"enum": ["poetic_brand_film", "functional_demonstration", "narrative_advertisement", "mixed_mode"]},
        "primary_mode": {"enum": ["poetic_brand_film", "functional_demonstration", "narrative_advertisement"]},
        "narrative_logic": {"type": "string", "minLength": 1},
        "product_expression": {"type": "string", "minLength": 1},
        "literal_usage_demo": {"type": "boolean"},
        "source_intent_preserved": {"const": true}
      }
    },
    "sourceInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "locator", "source_type", "file_sha256", "integrity_status", "authority_scope", "extraction_status"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^SOURCE_[A-Z0-9_-]+$"},
        "locator": {"type": "string", "minLength": 1},
        "source_type": {"enum": ["user_message", "rough_treatment", "structured_script_document", "brand_brief", "product_evidence", "approved_copy_document"]},
        "file_sha256": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^[a-f0-9]{64}$"}]},
        "integrity_status": {"enum": ["verified_bytes", "runtime_reference_bound", "unavailable"]},
        "authority_scope": {"$ref": "#/$defs/nonEmptyStrings"},
        "extraction_status": {"enum": ["complete", "partial"]}
      }
    },
    "directingGrammar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lens_and_scale_tendencies", "camera_movement_principles", "composition_rules", "cutting_motivations", "performance_restraint", "product_reveal_strategy", "motion_rhythm", "immutable_core"],
      "properties": {
        "lens_and_scale_tendencies": {"$ref": "#/$defs/nonEmptyStrings"},
        "camera_movement_principles": {"$ref": "#/$defs/nonEmptyStrings"},
        "composition_rules": {"$ref": "#/$defs/nonEmptyStrings"},
        "cutting_motivations": {"$ref": "#/$defs/nonEmptyStrings"},
        "performance_restraint": {"$ref": "#/$defs/nonEmptyStrings"},
        "product_reveal_strategy": {"$ref": "#/$defs/nonEmptyStrings"},
        "motion_rhythm": {"$ref": "#/$defs/nonEmptyStrings"},
        "immutable_core": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "productionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aspect_ratio", "distribution_context", "source_language", "copy_policy"],
      "properties": {
        "aspect_ratio": {"type": "string", "pattern": "^[0-9]+:[0-9]+$"},
        "distribution_context": {"$ref": "#/$defs/nonEmptyStrings"},
        "source_language": {"type": "string", "minLength": 2},
        "copy_policy": {"type": "string", "minLength": 3}
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_duration_seconds", "numerical_tolerance_seconds", "shot_count"],
      "properties": {
        "total_duration_seconds": {"type": "number", "exclusiveMinimum": 0},
        "numerical_tolerance_seconds": {"type": "number", "minimum": 0, "maximum": 0.01},
        "shot_count": {"type": "integer", "minimum": 1}
      }
    },
    "shot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shot_uid", "display_no", "target_duration_seconds", "submode", "narrative_function", "advertising_function",
        "subjects", "product_or_prop", "scene", "initial_state", "action_path", "ending_state", "shot_size", "camera_height",
        "camera_angle", "lens_intent", "composition", "subject_placement", "primary_camera_movement", "focus_behavior", "blocking",
        "screen_direction", "continuity_in", "continuity_out", "cut_motivation", "transition_intent", "visible_emotional_expression", "spoken_content", "on_screen_copy",
        "must_preserve", "must_avoid", "required_assets", "storyboard_requirement", "keyframe_requirement", "previs_requirement"
      ],
      "properties": {
        "shot_uid": {"$ref": "#/$defs/shotUid"},
        "display_no": {"type": "integer", "minimum": 1},
        "target_duration_seconds": {"type": "number", "exclusiveMinimum": 0},
        "submode": {"enum": ["poetic_brand_film", "functional_demonstration", "narrative_advertisement"]},
        "narrative_function": {"type": "string", "minLength": 3},
        "advertising_function": {"type": "string", "minLength": 3},
        "subjects": {"$ref": "#/$defs/nonEmptyStrings"},
        "product_or_prop": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "scene": {"type": "string", "minLength": 1},
        "initial_state": {"type": "string", "minLength": 3},
        "action_path": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
        "ending_state": {"type": "string", "minLength": 3},
        "shot_size": {"type": "string", "minLength": 1},
        "camera_height": {"type": "string", "minLength": 1},
        "camera_angle": {"type": "string", "minLength": 1},
        "lens_intent": {"type": "string", "minLength": 3},
        "composition": {"type": "string", "minLength": 3},
        "subject_placement": {"type": "string", "minLength": 3},
        "primary_camera_movement": {"type": "string", "minLength": 3},
        "focus_behavior": {"type": "string", "minLength": 3},
        "blocking": {"type": "string", "minLength": 3},
        "screen_direction": {"type": "string", "minLength": 3},
        "continuity_in": {"type": "string", "minLength": 3},
        "continuity_out": {"type": "string", "minLength": 3},
        "cut_motivation": {"type": "string", "minLength": 3},
        "transition_intent": {"type": "string", "minLength": 3},
        "visible_emotional_expression": {"type": "string", "minLength": 3},
        "spoken_content": {"$ref": "#/$defs/spokenContent"},
        "on_screen_copy": {"type": "array", "items": {"$ref": "#/$defs/onScreenCopy"}},
        "must_preserve": {"$ref": "#/$defs/nonEmptyStrings"},
        "must_avoid": {"$ref": "#/$defs/nonEmptyStrings"},
        "required_assets": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "storyboard_requirement": {"enum": ["required", "not_required"]},
        "keyframe_requirement": {"enum": ["required_single_anchor", "required_state_ladder", "recommended", "not_required"]},
        "previs_requirement": {"enum": ["required", "recommended", "not_required"]}
      }
    },
    "spokenContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "text", "copy_status", "source_reference_ids", "claim_ids"],
      "properties": {
        "mode": {"enum": ["none", "voiceover", "dialogue"]},
        "text": {"type": "string"},
        "copy_status": {"enum": ["not_used", "supplied_exact", "provisional_nonclaim", "source_supported_claim"]},
        "source_reference_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "claim_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^CLAIM_[A-Z0-9_-]+$"}}
      }
    },
    "onScreenCopy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "copy_status", "source_reference_ids", "claim_ids", "timing_intent"],
      "properties": {
        "text": {"type": "string", "minLength": 1},
        "copy_status": {"enum": ["supplied_exact", "provisional_nonclaim", "source_supported_claim"]},
        "source_reference_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "claim_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^CLAIM_[A-Z0-9_-]+$"}},
        "timing_intent": {"type": "string", "minLength": 1}
      }
    },
    "continuityEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_shot_uid", "to_shot_uid", "continuity_type", "preserved_state", "cut_reason"],
      "properties": {
        "from_shot_uid": {"$ref": "#/$defs/shotUid"},
        "to_shot_uid": {"$ref": "#/$defs/shotUid"},
        "continuity_type": {"enum": ["physical", "action_match", "screen_direction", "conceptual", "color_rhyme", "shape_rhyme", "texture_rhyme", "motion_rhyme", "intentional_discontinuity"]},
        "preserved_state": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "cut_reason": {"type": "string", "minLength": 3}
      }
    },
    "assetRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shot_uid", "requirements", "risk_note"],
      "properties": {
        "shot_uid": {"$ref": "#/$defs/shotUid"},
        "requirements": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "risk_note": {"type": "string", "minLength": 1}
      }
    },
    "keyframeRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shot_uid", "requirement", "reason"],
      "properties": {
        "shot_uid": {"$ref": "#/$defs/shotUid"},
        "requirement": {"enum": ["required_single_anchor", "required_state_ladder", "recommended", "not_required"]},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "previsRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shot_uid", "requirement", "reason"],
      "properties": {
        "shot_uid": {"$ref": "#/$defs/shotUid"},
        "requirement": {"enum": ["required", "recommended", "not_required"]},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "inference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_path", "decision", "rationale", "confidence", "source_basis", "reversible"],
      "properties": {
        "field_path": {"type": "string", "minLength": 1},
        "decision": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1},
        "confidence": {"enum": ["high", "medium", "low"]},
        "source_basis": {"type": "string", "minLength": 1},
        "reversible": {"type": "boolean"}
      }
    },
    "claimBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supplied_claims", "used_claim_ids", "prohibited_unsourced_claims", "compliance_unknowns", "claim_generation_status"],
      "properties": {
        "supplied_claims": {"type": "array", "items": {"$ref": "#/$defs/suppliedClaim"}},
        "used_claim_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^CLAIM_[A-Z0-9_-]+$"}},
        "prohibited_unsourced_claims": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "compliance_unknowns": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "claim_generation_status": {"enum": ["no_new_claims_added", "source_supported_claims_only", "blocked_unresolved_claim"]}
      }
    },
    "suppliedClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "text", "source_reference_ids"],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^CLAIM_[A-Z0-9_-]+$"},
        "text": {"type": "string", "minLength": 1},
        "source_reference_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "isolatedBlocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "blocker_type", "required_fact", "reason", "affected_shot_uids", "unaffected_work_completed"],
      "properties": {
        "blocker_id": {"type": "string", "minLength": 1},
        "blocker_type": {"enum": ["mutually_exclusive_brand_direction", "exact_legally_material_claim", "unavailable_exact_supplied_copy", "target_product_source_conflict"]},
        "required_fact": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "affected_shot_uids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/shotUid"}},
        "unaffected_work_completed": {"const": true}
      }
    },
    "revisionScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "requested_shot_uids", "actually_changed_shot_uids", "global_fields_changed", "expanded_dependency_reasons", "invalidated_artifact_ids", "preserved_artifact_ids", "predecessor_artifact", "changed_json_pointers"],
      "properties": {
        "mode": {"enum": ["initial", "selective_revision", "global_revision", "reorder"]},
        "requested_shot_uids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/shotUid"}},
        "actually_changed_shot_uids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/shotUid"}},
        "global_fields_changed": {"type": "boolean"},
        "expanded_dependency_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "invalidated_artifact_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "preserved_artifact_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "predecessor_artifact": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/dependency"}]},
        "changed_json_pointers": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^/"}}
      }
    }
  }
}
