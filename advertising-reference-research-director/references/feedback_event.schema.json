{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/advertising-reference-research-director/feedback_event.schema.json",
  "title": "Advertising Reference Feedback Ledger Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "feedback_id", "timestamp", "run_id", "intent_id", "pack_id", "feedback_class", "signal_class", "user_evidence_or_quote", "failed_assumption", "error_layer", "constraint_delta", "invalidated_candidate_ids", "invalidated_approach_ids", "invalidated_query_ids", "invalidated_artifact_refs", "repair_start_phase", "completion_evidence", "scope", "scope_evidence", "external_persistence_state", "confidence", "supersedes", "intent_version_before", "intent_version_after", "user_confirmed_persistence", "agent_trace"],
  "properties": {
    "schema_version": {"const": "1.2.0"},
    "feedback_id": {"type": "string", "pattern": "^feedback_[A-Za-z0-9._-]+$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "run_id": {"type": "string", "minLength": 1}, "intent_id": {"type": "string", "minLength": 1}, "pack_id": {"type": "string", "minLength": 1},
    "feedback_class": {"type": "string", "enum": ["intent_correction", "route_correction", "query_correction", "source_correction", "access_correction", "selection_correction", "diversity_correction", "presentation_correction", "rights_correction"]},
    "signal_class": {"type": "string", "enum": ["explicit_hard_constraint", "explicit_soft_preference", "inferred_session_signal", "confirmed_project_rule", "confirmed_global_rule"]},
    "user_evidence_or_quote": {"type": "string", "minLength": 1},
    "failed_assumption": {"type": "string", "minLength": 1},
    "error_layer": {"type": "string", "enum": ["intent", "route", "query", "source", "access", "scoring", "diversity", "presentation", "rights"]},
    "constraint_delta": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["target_artifact_type", "before_ref", "after_ref", "operation", "path", "before_exists", "after_exists", "before", "after", "reason"],
        "properties": {
          "target_artifact_type": {"type": "string", "enum": ["intent_brief", "approach_registry"]},
          "before_ref": {"type": "string", "minLength": 1},
          "after_ref": {"type": "string", "minLength": 1},
          "operation": {"type": "string", "enum": ["add", "remove", "replace"]}, "path": {"type": "string", "pattern": "^/"},
          "before_exists": {"type": "boolean"}, "after_exists": {"type": "boolean"},
          "before": {}, "after": {}, "reason": {"type": "string", "minLength": 20}
        }
      }
    },
    "invalidated_candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "invalidated_approach_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "invalidated_query_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "invalidated_artifact_refs": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["artifact_type", "ref", "reason"],
        "properties": {"artifact_type": {"type": "string", "enum": ["intent_brief", "approach_registry", "candidate", "verification_receipt", "browser_capture_record", "relevance_review", "diversity_review", "resolution_review", "shortlist_30", "selected_20", "rejected_10", "reference_board", "adversarial_audit", "verification_report"]}, "ref": {"type": "string", "minLength": 1}, "reason": {"type": "string", "minLength": 1}}
      }
    },
    "repair_start_phase": {"type": "string", "enum": ["intent_freeze", "routing", "orchestration", "discovery", "verification", "selection", "output"]},
    "completion_evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "completed_at", "artifact_bindings"],
      "properties": {
        "status": {"type": "string", "enum": ["pending", "applied"]},
        "completed_at": {"type": "string", "format": "date-time"},
        "artifact_bindings": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["artifact_type", "ref", "sha256"],
            "properties": {
              "artifact_type": {"type": "string", "enum": ["intent_brief", "approach_registry", "candidate", "verification_receipt", "browser_capture_record", "relevance_review", "diversity_review", "resolution_review", "shortlist_30", "selected_20", "rejected_10", "reference_board", "adversarial_audit"]},
              "ref": {"type": "string", "minLength": 1},
              "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
            }
          }
        }
      }
    },
    "scope": {"type": "string", "enum": ["session", "project", "global"]},
    "scope_evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["basis", "supporting_feedback_ids", "counterexamples_considered", "scope_owner", "reversal_procedure"],
      "properties": {
        "basis": {"type": "string", "enum": ["current_run_only", "explicit_user_confirmation", "repeated_corrections"]},
        "supporting_feedback_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^feedback_[A-Za-z0-9._-]+$"}},
        "counterexamples_considered": {"type": "string", "minLength": 20},
        "scope_owner": {"type": "string", "minLength": 1},
        "reversal_procedure": {"type": "string", "minLength": 20}
      }
    },
    "external_persistence_state": {"const": "not_applied_by_skill"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "supersedes": {"type": ["string", "null"]},
    "intent_version_before": {"type": "string", "pattern": "^v[1-9][0-9]*$"},
    "intent_version_after": {"type": "string", "pattern": "^v[1-9][0-9]*$"},
    "user_confirmed_persistence": {"type": "boolean"},
    "agent_trace": {
      "type": "object", "additionalProperties": false,
      "required": ["recorded_by", "applied_by", "applied_at"],
      "properties": {"recorded_by": {"type": "string", "minLength": 1}, "applied_by": {"type": "string", "minLength": 1}, "applied_at": {"type": "string", "format": "date-time"}}
    }
  },
  "allOf": [
    {"if": {"properties": {"scope": {"const": "global"}}}, "then": {"properties": {"user_confirmed_persistence": {"const": true}}}}
  ]
}
