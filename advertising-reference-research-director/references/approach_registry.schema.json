{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/advertising-reference-research-director/approach_registry.schema.json",
  "title": "Advertising Reference Research Approach Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_id", "run_id", "intent_id", "intent_version", "created_at", "registration", "independence_policy", "agents", "approaches", "coverage"],
  "properties": {
    "schema_version": {"const": "1.4.0"},
    "registry_id": {"type": "string", "pattern": "^approach_registry_[A-Za-z0-9._-]+$"},
    "run_id": {"type": "string", "minLength": 1},
    "intent_id": {"type": "string", "minLength": 1},
    "intent_version": {"type": "string", "pattern": "^v[1-9][0-9]*$"},
    "created_at": {"type": "string", "format": "date-time"},
    "registration": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "frozen_at", "plan_sha256", "canonicalization"],
      "properties": {
        "kind": {"type": "string", "enum": ["synthetic_fixture", "retrospective_reconstruction", "preregistered"]},
        "frozen_at": {"type": "string", "format": "date-time"},
        "plan_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "canonicalization": {"const": "sorted-json-v1"}
      }
    },
    "independence_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["finder_cannot_approve_own_candidate", "verifier_must_differ_from_finder", "capture_operator_must_differ_from_finder_and_verifier", "decision_roles_use_distinct_agent_ids", "blind_curators_share_frozen_input", "final_auditor_independent", "scouts_route_blinded"],
      "properties": {
        "finder_cannot_approve_own_candidate": {"const": true},
        "verifier_must_differ_from_finder": {"const": true},
        "capture_operator_must_differ_from_finder_and_verifier": {"const": true},
        "decision_roles_use_distinct_agent_ids": {"const": true},
        "blind_curators_share_frozen_input": {"const": true},
        "final_auditor_independent": {"const": true},
        "scouts_route_blinded": {"const": true}
      }
    },
    "agents": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["agent_id", "role", "access_scope", "session_owner"],
        "properties": {
          "agent_id": {"type": "string", "minLength": 1},
          "role": {"type": "string", "enum": ["search_scout", "credit_graph_scout", "authenticated_source_operator", "capture_operator", "verification_agent", "relevance_curator", "diversity_curator", "adversarial_auditor", "root_synthesizer"]},
          "additional_roles": {
            "type": "array", "uniqueItems": true,
            "items": {"type": "string", "enum": ["search_scout", "credit_graph_scout", "authenticated_source_operator", "capture_operator", "verification_agent", "relevance_curator", "diversity_curator", "adversarial_auditor", "root_synthesizer"]}
          },
          "access_scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "enum": ["public", "signed_chrome", "subscription", "geo_or_age_gated"]}},
          "session_owner": {"type": "boolean"}
        }
      }
    },
    "approaches": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["approach_id", "pack_id", "modality", "decision_axis", "method", "hypothesis", "queries", "source_family_ids", "executing_agent_id", "favored_route_disclosed", "started_at", "returned_count", "qualified_count", "qualification_rate", "failure_records", "next_round_adjustment", "status"],
        "properties": {
          "approach_id": {"type": "string", "minLength": 1},
          "pack_id": {"type": "string", "minLength": 1},
          "modality": {"type": "string", "enum": ["image", "video", "mixed"]},
          "decision_axis": {"type": "string", "minLength": 1},
          "method": {"$ref": "#/$defs/method"},
          "hypothesis": {"type": "string", "minLength": 1},
          "queries": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["query_id", "query_text", "locale", "round"],
              "properties": {
                "query_id": {"type": "string", "minLength": 1},
                "query_text": {"type": "string", "minLength": 1},
                "locale": {"type": "string", "minLength": 2},
                "round": {"type": "integer", "minimum": 1}
              }
            }
          },
          "source_family_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "executing_agent_id": {"type": "string", "minLength": 1},
          "favored_route_disclosed": {"const": false},
          "started_at": {"type": "string", "format": "date-time"},
          "returned_count": {"type": "integer", "minimum": 0},
          "qualified_count": {"type": "integer", "minimum": 0},
          "qualification_rate": {"type": "number", "minimum": 0, "maximum": 1},
          "failure_records": {
            "type": "array",
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["failure_id", "query_id", "source_family_id", "round", "failure_code", "candidate_ids", "receipt_ids", "observed_at", "reason", "fallback_action"],
              "properties": {
                "failure_id": {"type": "string", "pattern": "^failure_[A-Za-z0-9._-]+$"},
                "query_id": {"type": "string", "minLength": 1},
                "source_family_id": {"type": "string", "minLength": 1},
                "round": {"type": "integer", "minimum": 1},
                "failure_code": {"type": "string", "enum": ["screened_out", "access_blocked", "duplicate", "irrelevant", "provenance_unconfirmed", "rights_blocked", "zero_yield", "other"]},
                "candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
                "receipt_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
                "observed_at": {"type": "string", "format": "date-time"},
                "reason": {"type": "string", "minLength": 20},
                "fallback_action": {"type": "string", "minLength": 20}
              }
            }
          },
          "next_round_adjustment": {"type": ["string", "null"], "minLength": 20},
          "status": {"type": "string", "enum": ["planned", "running", "complete", "abandoned"]}
        }
      }
    },
    "coverage": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["pack_id", "modality", "required_distinct_method_count", "declared_distinct_method_count", "covered_methods", "coverage_asserted"],
        "properties": {
          "pack_id": {"type": "string", "minLength": 1},
          "modality": {"type": "string", "enum": ["image", "video", "mixed"]},
          "required_distinct_method_count": {"const": 3},
          "declared_distinct_method_count": {"type": "integer", "minimum": 3, "maximum": 6},
          "covered_methods": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"$ref": "#/$defs/method"}},
          "coverage_asserted": {"const": true}
        }
      }
    }
  },
  "$defs": {
    "method": {"type": "string", "enum": ["direct_category", "visual_temporal_mechanism", "credit_graph", "award_editorial_official", "adjacent_discipline", "challenger"]}
  }
}
