{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/advertising-reference-research-director/selected_20.schema.json",
  "title": "Selected References of Exactly 20",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "intent_id", "intent_version", "pack_id", "created_at", "selected_candidate_count", "items", "curation_trace", "diversity_policy", "integrity_assertions"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string", "minLength": 1}, "intent_id": {"type": "string", "minLength": 1}, "intent_version": {"type": "string", "pattern": "^v[1-9][0-9]*$"}, "pack_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "selected_candidate_count": {"const": 20},
    "items": {
      "type": "array", "minItems": 20, "maxItems": 20,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["candidate_id", "rank", "verification_receipt_id", "territory_id", "why_fit", "decision_supported", "transferable_mechanism", "do_not_copy", "source_tags", "access_tags", "rights_tags", "diversity_contribution"],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1}, "rank": {"type": "integer", "minimum": 1, "maximum": 20}, "verification_receipt_id": {"type": "string", "minLength": 1}, "territory_id": {"type": "string", "minLength": 1},
          "why_fit": {"type": "string", "minLength": 1}, "decision_supported": {"type": "string", "minLength": 1}, "transferable_mechanism": {"type": "string", "minLength": 1}, "do_not_copy": {"type": "string", "minLength": 1},
          "source_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "access_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "rights_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "diversity_contribution": {"type": "string", "minLength": 1}
        }
      }
    },
    "curation_trace": {
      "type": "object", "additionalProperties": false,
      "required": ["relevance_curator_id", "diversity_curator_id", "root_synthesizer_id", "relevance_review_ref", "diversity_review_ref", "resolution_ref"],
      "properties": {"relevance_curator_id": {"type": "string", "minLength": 1}, "diversity_curator_id": {"type": "string", "minLength": 1}, "root_synthesizer_id": {"type": "string", "minLength": 1}, "relevance_review_ref": {"type": "string", "minLength": 1}, "diversity_review_ref": {"type": "string", "minLength": 1}, "resolution_ref": {"type": ["string", "null"]}}
    },
    "diversity_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["broad_brief", "distinct_domains", "distinct_source_families", "territory_count", "max_per_domain", "max_per_campaign_or_creator", "max_per_near_duplicate_group", "waiver"],
      "properties": {
        "broad_brief": {"type": "boolean"}, "distinct_domains": {"type": "integer", "minimum": 1}, "distinct_source_families": {"type": "integer", "minimum": 1}, "territory_count": {"type": "integer", "minimum": 1},
        "max_per_domain": {"type": "integer", "minimum": 1}, "max_per_campaign_or_creator": {"type": "integer", "minimum": 1}, "max_per_near_duplicate_group": {"type": "integer", "minimum": 1},
        "waiver": {"type": ["object", "null"], "additionalProperties": false, "required": ["constraints", "reason", "evidence", "remaining_risk", "approved_by"], "properties": {"constraints": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "enum": ["min_domains", "min_source_families", "territory_count", "max_per_domain", "max_per_campaign_or_creator", "max_per_near_duplicate_group"]}}, "reason": {"type": "string", "minLength": 1}, "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "remaining_risk": {"type": "string", "minLength": 1}, "approved_by": {"type": "string", "minLength": 1}}}
      }
    },
    "integrity_assertions": {
      "type": "object", "additionalProperties": false,
      "required": ["selected_subset_of_shortlist", "candidate_ids_unique", "ranks_unique_and_complete", "all_receipts_fresh", "all_rights_assessed"],
      "properties": {"selected_subset_of_shortlist": {"const": true}, "candidate_ids_unique": {"const": true}, "ranks_unique_and_complete": {"const": true}, "all_receipts_fresh": {"const": true}, "all_rights_assessed": {"const": true}}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"diversity_policy": {"properties": {"broad_brief": {"const": true}, "waiver": {"type": "null"}}}}},
      "then": {"properties": {"diversity_policy": {"properties": {"distinct_domains": {"minimum": 5}, "distinct_source_families": {"minimum": 4}, "territory_count": {"minimum": 4, "maximum": 6}, "max_per_domain": {"maximum": 4}, "max_per_campaign_or_creator": {"maximum": 2}, "max_per_near_duplicate_group": {"maximum": 1}}}}}
    }
  ]
}
