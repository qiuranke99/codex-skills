{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "appearance_decomposition.schema.json",
  "title": "Source Appearance Decomposition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scene_id",
    "source_reference_ids",
    "heavy_look_detected",
    "source_color_cast",
    "source_exposure_state",
    "source_contrast_state",
    "source_key_light_direction",
    "shadow_compression",
    "highlight_clipping",
    "bloom_flare",
    "depth_of_field",
    "grading_characteristics",
    "atmosphere_or_medium_state",
    "intrinsic_scene_appearance",
    "intrinsic_scene_state",
    "external_illumination",
    "camera_optical_effects",
    "postprocess_effects",
    "unresolved_appearance",
    "material_color_inferences",
    "intrinsic_emissive_structures",
    "neutral_appearance_canon",
    "neutralization_strategy",
    "appearance_revision",
    "appearance_freeze_status"
  ],
  "properties": {
    "schema_version": {"const": "scene-appearance-decomposition.v1"},
    "scene_id": {"type": "string", "minLength": 1},
    "source_reference_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "heavy_look_detected": {"type": "boolean"},
    "source_color_cast": {"type": "array", "items": {"type": "string"}},
    "source_exposure_state": {"type": "array", "items": {"type": "string"}},
    "source_contrast_state": {"type": "array", "items": {"type": "string"}},
    "source_key_light_direction": {"type": "array", "items": {"type": "string"}},
    "shadow_compression": {"enum": ["none", "mild", "strong", "unknown"]},
    "highlight_clipping": {"enum": ["none", "mild", "strong", "unknown"]},
    "bloom_flare": {"type": "array", "items": {"type": "string"}},
    "depth_of_field": {"type": "string"},
    "grading_characteristics": {"type": "array", "items": {"type": "string"}},
    "atmosphere_or_medium_state": {"type": "array", "items": {"type": "string"}},
    "intrinsic_scene_appearance": {"type": "array", "items": {"$ref": "#/$defs/appearanceItem"}},
    "intrinsic_scene_state": {"type": "array", "items": {"$ref": "#/$defs/stateItem"}},
    "external_illumination": {"type": "array", "items": {"$ref": "#/$defs/removableItem"}},
    "camera_optical_effects": {"type": "array", "items": {"$ref": "#/$defs/removableItem"}},
    "postprocess_effects": {"type": "array", "items": {"$ref": "#/$defs/removableItem"}},
    "unresolved_appearance": {"type": "array", "items": {"type": "string"}},
    "material_color_inferences": {"type": "array", "items": {"$ref": "#/$defs/materialInference"}},
    "intrinsic_emissive_structures": {"type": "array", "items": {"$ref": "#/$defs/emissiveItem"}},
    "neutral_appearance_canon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["white_balance", "illumination", "contrast", "shadow_rule", "highlight_rule", "depth_of_field_rule", "material_rule", "state_rule", "forbidden_look_components"],
      "properties": {
        "white_balance": {"type": "string"},
        "illumination": {"type": "string"},
        "contrast": {"type": "string"},
        "shadow_rule": {"type": "string"},
        "highlight_rule": {"type": "string"},
        "depth_of_field_rule": {"type": "string"},
        "material_rule": {"type": "string"},
        "state_rule": {"type": "string"},
        "forbidden_look_components": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "neutralization_strategy": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "appearance_revision": {"type": "string", "minLength": 1},
    "appearance_freeze_status": {"enum": ["draft", "frozen", "reopened_for_repair"]}
  },
  "$defs": {
    "appearanceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_or_feature", "property", "source_status", "confidence"],
      "properties": {"surface_or_feature": {"type": "string"}, "property": {"type": "string"}, "source_status": {"enum": ["source_locked", "source_corroborated", "estimated_intrinsic_appearance"]}, "confidence": {"enum": ["high", "medium", "low"]}}
    },
    "stateItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "identity_defining", "preserve"],
      "properties": {"state": {"type": "string"}, "identity_defining": {"type": "boolean"}, "preserve": {"type": "boolean"}, "reason": {"type": "string"}}
    },
    "removableItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect", "remove_from_neutral_assets"],
      "properties": {"effect": {"type": "string"}, "remove_from_neutral_assets": {"const": true}, "evidence": {"type": "string"}}
    },
    "materialInference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "observed_rendered_color", "intrinsic_base_color", "confidence", "status"],
      "properties": {"surface_id": {"type": "string"}, "observed_rendered_color": {"type": "string"}, "intrinsic_base_color": {"type": "string"}, "confidence": {"enum": ["high", "medium", "low"]}, "status": {"enum": ["confirmed", "estimated_intrinsic_appearance", "unresolved"]}}
    },
    "emissiveItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "intrinsic", "preservation_rule"],
      "properties": {"feature": {"type": "string"}, "intrinsic": {"const": true}, "preservation_rule": {"type": "string"}}
    }
  }
}
