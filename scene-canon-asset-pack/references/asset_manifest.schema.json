{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_manifest.schema.json",
  "title": "Scene Canon Six-Asset Delivery Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "package_id", "scene_id", "canon_revision", "canon_sha256",
    "appearance_revision", "appearance_sha256", "completion_hash", "motion_profile_id",
    "package_status", "task_finalization_status", "assistant_qa_status",
    "production_approval_status", "runtime_evidence_origin", "scene_canon_path",
    "appearance_decomposition_path", "generation_prompt_document_path",
    "generation_prompt_document_sha256", "prompt_publication_receipt_path",
    "prompt_publication_receipt_sha256", "generation_queue", "generation_prompt_records",
    "assets", "four_k_prompt_records", "structured_qa_records",
    "approved_machine_asset_count", "four_k_prompt_mapping_count",
    "human_review_overview_board", "repair_log", "qa_report_path",
    "look_contamination_report_path", "coverage_graph_report_path",
    "four_k_prompt_mapping_report_path"
  ],
  "properties": {
    "schema_version": {"const": "scene-canon-asset-manifest.v2"},
    "package_id": {"type": "string", "minLength": 1},
    "scene_id": {"type": "string", "minLength": 1},
    "canon_revision": {"type": "string", "minLength": 1},
    "canon_sha256": {"$ref": "#/$defs/sha256"},
    "appearance_revision": {"type": "string", "minLength": 1},
    "appearance_sha256": {"$ref": "#/$defs/sha256"},
    "completion_hash": {"$ref": "#/$defs/sha256"},
    "motion_profile_id": {"const": "scene_motion_six.v1"},
    "package_status": {"enum": ["draft", "prompts_frozen", "prompts_published", "generating", "repair_required", "graph_qa_pending", "four_k_mapping_failed", "packaged", "blocked_missing_scene_reference", "blocked_exactness_evidence", "blocked_prompt_publication", "blocked_worker_runtime", "hard_blocked_generation_runtime"]},
    "task_finalization_status": {"enum": ["not_started", "in_progress", "ready_to_publish", "complete", "blocked"]},
    "assistant_qa_status": {"enum": ["not_reviewed", "failed", "passed", "blocked"]},
    "production_approval_status": {"enum": ["not_granted", "user_granted", "external_pipeline_granted"]},
    "runtime_evidence_origin": {"enum": ["live_runtime", "deterministic_contract_fixture"]},
    "scene_canon_path": {"const": "00_manifest/SCENE_CANON.json"},
    "appearance_decomposition_path": {"const": "00_manifest/SOURCE_APPEARANCE_DECOMPOSITION.json"},
    "generation_prompt_document_path": {"const": "00_manifest/GENERATION_PROMPTS.md"},
    "generation_prompt_document_sha256": {"$ref": "#/$defs/sha256"},
    "prompt_publication_receipt_path": {"const": "10_runtime/prompt-publication-receipt.json"},
    "prompt_publication_receipt_sha256": {"$ref": "#/$defs/sha256"},
    "generation_queue": {"$ref": "#/$defs/generationQueue"},
    "generation_prompt_records": {"type": "array", "items": {"$ref": "#/$defs/generationPrompt"}},
    "assets": {"type": "array", "minItems": 7, "items": {"$ref": "#/$defs/asset"}},
    "four_k_prompt_records": {"type": "array", "items": {"$ref": "#/$defs/fourKPrompt"}},
    "structured_qa_records": {"type": "array", "items": {"$ref": "#/$defs/qaRecord"}},
    "approved_machine_asset_count": {"type": "integer", "minimum": 0},
    "four_k_prompt_mapping_count": {"type": "integer", "minimum": 0},
    "human_review_overview_board": {"type": ["string", "null"]},
    "repair_log": {"type": "array", "items": {"$ref": "#/$defs/repairRecord"}},
    "qa_report_path": {"const": "09_qa/QA_REPORT.md"},
    "look_contamination_report_path": {"const": "09_qa/look_contamination_report.md"},
    "coverage_graph_report_path": {"const": "09_qa/coverage_graph_report.md"},
    "four_k_prompt_mapping_report_path": {"const": "09_qa/4k_prompt_mapping_report.md"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "dimensions": {"type": "object", "additionalProperties": false, "required": ["width", "height"], "properties": {"width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}}},
    "generationQueue": {
      "type": "object", "additionalProperties": false,
      "required": ["ordered_asset_ids", "status", "current_asset_id", "next_asset_id", "max_parallel_workers", "user_continuation_required", "first_worker_spawn_elapsed_ms", "last_worker_complete_elapsed_ms"],
      "properties": {
        "ordered_asset_ids": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"type": "string"}},
        "status": {"enum": ["planned", "running", "repair_required", "complete", "blocked"]},
        "current_asset_id": {"type": ["string", "null"]}, "next_asset_id": {"type": ["string", "null"]},
        "max_parallel_workers": {"const": 1}, "user_continuation_required": {"const": false},
        "first_worker_spawn_elapsed_ms": {"type": ["integer", "null"], "minimum": 0},
        "last_worker_complete_elapsed_ms": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "referencePlanItem": {
      "type": "object", "additionalProperties": false,
      "required": ["index", "alias", "kind", "source_reference_id", "predecessor_asset_id"],
      "properties": {
        "index": {"type": "integer", "minimum": 1}, "alias": {"type": "string", "minLength": 1},
        "kind": {"enum": ["source_reference", "approved_predecessor"]},
        "source_reference_id": {"type": ["string", "null"]},
        "predecessor_asset_id": {"type": ["string", "null"]}
      }
    },
    "generationPrompt": {
      "type": "object", "additionalProperties": false,
      "required": ["prompt_id", "asset_id", "coverage_node_id", "generation_order", "dependency_stage", "dependency_asset_ids", "reference_plan", "prompt_body", "prompt_sha256", "status"],
      "properties": {
        "prompt_id": {"type": "string", "pattern": "^GEN_[A-Z0-9_-]+$"},
        "asset_id": {"type": "string"}, "coverage_node_id": {"type": "string"},
        "generation_order": {"type": "integer", "minimum": 1}, "dependency_stage": {"type": "integer", "minimum": 1},
        "dependency_asset_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "reference_plan": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/referencePlanItem"}},
        "prompt_body": {"type": "string", "minLength": 400}, "prompt_sha256": {"$ref": "#/$defs/sha256"},
        "status": {"enum": ["frozen_unpublished", "published", "stale_after_repair"]}
      }
    },
    "contaminationFlags": {
      "type": "object", "additionalProperties": false,
      "required": ["text_or_layout", "person", "product", "temporary_object", "look_contamination"],
      "properties": {"text_or_layout": {"type": "boolean"}, "person": {"type": "boolean"}, "product": {"type": "boolean"}, "temporary_object": {"type": "boolean"}, "look_contamination": {"type": "boolean"}}
    },
    "asset": {
      "type": "object", "additionalProperties": false,
      "required": [
        "asset_id", "asset_name", "asset_type", "mandatory_role", "coverage_node_id",
        "generation_order", "dependency_stage", "dependency_asset_ids", "asset_revision",
        "file_path", "file_sha256", "is_machine_asset", "independently_generated",
        "derived_from_multipanel", "generation_mode", "generation_status", "accepted_attempt_id",
        "assistant_qa_status", "production_approval_status", "actual_pixel_dimensions",
        "actual_dimensions_verified", "target_pixel_dimensions", "native_4k_claim",
        "source_reference_ids", "canon_sha256", "appearance_sha256", "completion_hash",
        "scene_canon_version", "neutral_appearance_version", "contamination_flags",
        "generation_prompt_id", "worker_result_path", "worker_result_sha256",
        "inspection_receipt_path", "inspection_receipt_sha256", "four_k_prompt_id"
      ],
      "properties": {
        "asset_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]+$"},
        "asset_name": {"type": "string", "minLength": 1},
        "asset_type": {"enum": ["canonical_diagnostic_master", "spatial_relational_master", "coverage_plate", "scale_landmark", "human_review_overview_board"]},
        "mandatory_role": {"type": ["string", "null"]}, "coverage_node_id": {"type": ["string", "null"]},
        "generation_order": {"type": ["integer", "null"], "minimum": 1}, "dependency_stage": {"type": ["integer", "null"], "minimum": 1},
        "dependency_asset_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "asset_revision": {"type": "integer", "minimum": 1}, "file_path": {"type": "string", "minLength": 1},
        "file_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "is_machine_asset": {"type": "boolean"}, "independently_generated": {"type": "boolean"}, "derived_from_multipanel": {"type": "boolean"},
        "generation_mode": {"enum": ["independent_full_frame", "approved_asset_composite"]},
        "generation_status": {"enum": ["planned", "spec_frozen", "worker_running", "result_bound", "inspection_pending", "generated", "regenerated", "failed", "blocked"]},
        "accepted_attempt_id": {"type": ["string", "null"]},
        "assistant_qa_status": {"enum": ["not_reviewed", "failed", "approved", "blocked"]},
        "production_approval_status": {"enum": ["not_granted", "user_granted", "external_pipeline_granted"]},
        "actual_pixel_dimensions": {"$ref": "#/$defs/dimensions"}, "actual_dimensions_verified": {"type": "boolean"},
        "target_pixel_dimensions": {"$ref": "#/$defs/dimensions"}, "native_4k_claim": {"type": "boolean"},
        "native_4k_evidence": {"type": ["string", "null"]},
        "source_reference_ids": {"type": "array", "items": {"type": "string"}},
        "canon_sha256": {"$ref": "#/$defs/sha256"}, "appearance_sha256": {"$ref": "#/$defs/sha256"}, "completion_hash": {"$ref": "#/$defs/sha256"},
        "scene_canon_version": {"type": "string", "minLength": 1}, "neutral_appearance_version": {"type": "string", "minLength": 1},
        "contamination_flags": {"$ref": "#/$defs/contaminationFlags"},
        "generation_prompt_id": {"type": ["string", "null"]},
        "worker_result_path": {"type": ["string", "null"]}, "worker_result_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "inspection_receipt_path": {"type": ["string", "null"]}, "inspection_receipt_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "four_k_prompt_id": {"type": ["string", "null"]}
      }
    },
    "fourKPrompt": {
      "type": "object", "additionalProperties": false,
      "required": ["prompt_id", "asset_id", "asset_name", "source_image", "source_dimensions", "target_dimensions", "asset_type", "required_reference_images", "reference_priority", "primary_reference_asset_id", "preservation_checklist", "allowed_enhancements", "forbidden_structural_changes", "forbidden_look_changes", "regeneration_prompt_en", "negative_constraints", "post_generation_qa_checklist", "source_asset_revision", "source_asset_sha256", "source_canon_sha256", "source_appearance_sha256", "source_completion_hash", "status"],
      "properties": {
        "prompt_id": {"type": "string", "pattern": "^4K_[A-Z0-9_-]+$"}, "asset_id": {"type": "string"}, "asset_name": {"type": "string"},
        "source_image": {"type": "string"}, "source_dimensions": {"$ref": "#/$defs/dimensions"}, "target_dimensions": {"$ref": "#/$defs/dimensions"},
        "asset_type": {"type": "string"}, "required_reference_images": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "reference_priority": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "primary_reference_asset_id": {"type": "string"},
        "preservation_checklist": {"type": "array", "minItems": 8, "items": {"type": "string"}},
        "allowed_enhancements": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "forbidden_structural_changes": {"type": "array", "minItems": 5, "items": {"type": "string"}},
        "forbidden_look_changes": {"type": "array", "minItems": 5, "items": {"type": "string"}},
        "regeneration_prompt_en": {"type": "string", "minLength": 200},
        "negative_constraints": {"type": "array", "minItems": 5, "items": {"type": "string"}},
        "post_generation_qa_checklist": {"type": "array", "minItems": 5, "items": {"type": "string"}},
        "source_asset_revision": {"type": "integer", "minimum": 1}, "source_asset_sha256": {"$ref": "#/$defs/sha256"},
        "source_canon_sha256": {"$ref": "#/$defs/sha256"}, "source_appearance_sha256": {"$ref": "#/$defs/sha256"}, "source_completion_hash": {"$ref": "#/$defs/sha256"},
        "status": {"enum": ["draft_pre_qa", "finalized_post_qa", "stale_after_asset_regeneration"]}
      }
    },
    "qaRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["check_id", "scope", "subject_ids", "status", "applicability", "evidence_summary", "bound_asset_sha256", "inspection_receipt_ids"],
      "properties": {
        "check_id": {"type": "string", "minLength": 1}, "scope": {"enum": ["asset", "edge", "path", "loop", "package"]},
        "subject_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "status": {"enum": ["passed", "failed"]},
        "applicability": {"enum": ["required", "not_applicable_with_reason"]}, "evidence_summary": {"type": "string", "minLength": 20},
        "bound_asset_sha256": {"type": "array", "items": {"$ref": "#/$defs/sha256"}},
        "inspection_receipt_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "repairRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["asset_id", "from_revision", "to_revision", "failure_root_cause", "invalidated_asset_ids", "invalidated_prompt_ids"],
      "properties": {
        "asset_id": {"type": "string"}, "from_revision": {"type": "integer", "minimum": 1}, "to_revision": {"type": "integer", "minimum": 2},
        "failure_root_cause": {"type": "string", "minLength": 1}, "invalidated_asset_ids": {"type": "array", "items": {"type": "string"}},
        "invalidated_prompt_ids": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
