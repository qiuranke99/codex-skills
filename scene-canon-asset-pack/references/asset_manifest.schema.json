{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_manifest.schema.json",
  "title": "Scene Canon Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "scene_id",
    "canon_revision",
    "canon_sha256",
    "appearance_revision",
    "appearance_sha256",
    "completion_hash",
    "package_status",
    "task_finalization_status",
    "assistant_qa_status",
    "production_approval_status",
    "scene_canon_path",
    "appearance_decomposition_path",
    "assets",
    "four_k_prompt_records",
    "approved_machine_asset_count",
    "four_k_prompt_mapping_count",
    "human_review_overview_board",
    "repair_log",
    "qa_report_path",
    "look_contamination_report_path",
    "four_k_prompt_mapping_report_path"
  ],
  "properties": {
    "schema_version": {"const": "scene-canon-asset-manifest.v1"},
    "package_id": {"type": "string", "minLength": 1},
    "scene_id": {"type": "string", "minLength": 1},
    "canon_revision": {"type": "string", "minLength": 1},
    "canon_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "appearance_revision": {"type": "string", "minLength": 1},
    "appearance_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "completion_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "package_status": {"enum": ["draft", "generating", "awaiting_post_generation_continuation", "pending_post_generation_inspection", "repair_required", "four_k_mapping_failed", "packaged", "blocked_missing_scene_reference", "blocked_exactness_evidence", "hard_blocked_generation_runtime"]},
    "task_finalization_status": {"enum": ["not_started", "in_progress", "awaiting_post_generation_continuation", "pending_post_generation_inspection", "ready_to_publish", "complete", "blocked"]},
    "assistant_qa_status": {"enum": ["not_reviewed", "failed", "passed", "blocked"]},
    "production_approval_status": {"enum": ["not_granted", "user_granted", "external_pipeline_granted"]},
    "scene_canon_path": {"const": "00_manifest/SCENE_CANON.json"},
    "appearance_decomposition_path": {"const": "00_manifest/SOURCE_APPEARANCE_DECOMPOSITION.json"},
    "assets": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/asset"}},
    "four_k_prompt_records": {"type": "array", "items": {"$ref": "#/$defs/fourKPrompt"}},
    "approved_machine_asset_count": {"type": "integer", "minimum": 0},
    "four_k_prompt_mapping_count": {"type": "integer", "minimum": 0},
    "human_review_overview_board": {"type": ["string", "null"]},
    "repair_log": {"type": "array", "items": {"$ref": "#/$defs/repairRecord"}},
    "qa_report_path": {"const": "09_qa/QA_REPORT.md"},
    "look_contamination_report_path": {"const": "09_qa/look_contamination_report.md"},
    "four_k_prompt_mapping_report_path": {"const": "09_qa/4k_prompt_mapping_report.md"}
  },
  "$defs": {
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {"width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}}
    },
    "contaminationFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text_or_layout", "person", "product", "temporary_object", "look_contamination"],
      "properties": {"text_or_layout": {"type": "boolean"}, "person": {"type": "boolean"}, "product": {"type": "boolean"}, "temporary_object": {"type": "boolean"}, "look_contamination": {"type": "boolean"}}
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "asset_name",
        "asset_type",
        "asset_revision",
        "file_path",
        "file_sha256",
        "is_machine_asset",
        "independently_generated",
        "derived_from_multipanel",
        "generation_mode",
        "terminal_generation_call",
        "generation_turn",
        "inspection_turn",
        "generation_status",
        "assistant_qa_status",
        "production_approval_status",
        "actual_pixel_dimensions",
        "actual_dimensions_verified",
        "target_pixel_dimensions",
        "native_4k_claim",
        "source_reference_ids",
        "canon_sha256",
        "appearance_sha256",
        "completion_hash",
        "scene_canon_version",
        "neutral_appearance_version",
        "contamination_flags",
        "four_k_prompt_id"
      ],
      "properties": {
        "asset_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]+$"},
        "asset_name": {"type": "string", "minLength": 1},
        "asset_type": {"enum": ["canonical_diagnostic_master", "spatial_relational_master", "coverage_plate", "scale_landmark", "intrinsic_scene_state", "human_review_overview_board"]},
        "asset_revision": {"type": "integer", "minimum": 1},
        "file_path": {"type": "string", "minLength": 1},
        "file_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "is_machine_asset": {"type": "boolean"},
        "independently_generated": {"type": "boolean"},
        "derived_from_multipanel": {"type": "boolean"},
        "generation_mode": {"enum": ["independent_full_frame", "approved_asset_composite"]},
        "terminal_generation_call": {"enum": ["not_started", "pending", "executed", "not_applicable_composite"]},
        "generation_turn": {"type": ["integer", "null"], "minimum": 1},
        "inspection_turn": {"type": ["integer", "null"], "minimum": 1},
        "generation_status": {"enum": ["planned", "spec_frozen", "awaiting_post_generation_continuation", "pending_post_generation_inspection", "stage_complete", "generated", "regenerated", "failed", "blocked"]},
        "assistant_qa_status": {"enum": ["not_reviewed", "failed", "approved", "blocked"]},
        "production_approval_status": {"enum": ["not_granted", "user_granted", "external_pipeline_granted"]},
        "actual_pixel_dimensions": {"$ref": "#/$defs/dimensions"},
        "actual_dimensions_verified": {"type": "boolean"},
        "target_pixel_dimensions": {"$ref": "#/$defs/dimensions"},
        "native_4k_claim": {"type": "boolean"},
        "native_4k_evidence": {"type": ["string", "null"]},
        "source_reference_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "canon_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "appearance_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "completion_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "scene_canon_version": {"type": "string", "minLength": 1},
        "neutral_appearance_version": {"type": "string", "minLength": 1},
        "contamination_flags": {"$ref": "#/$defs/contaminationFlags"},
        "four_k_prompt_id": {"type": ["string", "null"]}
      }
    },
    "fourKPrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_id",
        "asset_id",
        "asset_name",
        "source_image",
        "source_dimensions",
        "target_dimensions",
        "asset_type",
        "required_reference_images",
        "reference_priority",
        "primary_reference_asset_id",
        "preservation_checklist",
        "allowed_enhancements",
        "forbidden_structural_changes",
        "forbidden_look_changes",
        "regeneration_prompt_en",
        "negative_constraints",
        "post_generation_qa_checklist",
        "source_asset_revision",
        "source_asset_sha256",
        "source_canon_sha256",
        "source_appearance_sha256",
        "source_completion_hash",
        "status"
      ],
      "properties": {
        "prompt_id": {"type": "string", "pattern": "^4K_[A-Z0-9_-]+$"},
        "asset_id": {"type": "string"},
        "asset_name": {"type": "string"},
        "source_image": {"type": "string"},
        "source_dimensions": {"$ref": "#/$defs/dimensions"},
        "target_dimensions": {"$ref": "#/$defs/dimensions"},
        "asset_type": {"type": "string"},
        "required_reference_images": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "reference_priority": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "primary_reference_asset_id": {"type": "string"},
        "preservation_checklist": {"type": "array", "minItems": 8, "items": {"type": "string"}},
        "allowed_enhancements": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "forbidden_structural_changes": {"type": "array", "minItems": 5, "items": {"type": "string"}},
        "forbidden_look_changes": {"type": "array", "minItems": 5, "items": {"type": "string"}},
        "regeneration_prompt_en": {"type": "string", "minLength": 200},
        "negative_constraints": {"type": "array", "minItems": 5, "items": {"type": "string"}},
        "post_generation_qa_checklist": {"type": "array", "minItems": 5, "items": {"type": "string"}},
        "source_asset_revision": {"type": "integer", "minimum": 1},
        "source_asset_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_canon_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_appearance_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_completion_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "status": {"enum": ["draft_pre_qa", "finalized_post_qa", "stale_after_asset_regeneration"]}
      }
    },
    "repairRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_id", "from_revision", "to_revision", "failure_root_cause", "invalidated_prompt_ids"],
      "properties": {
        "asset_id": {"type": "string"},
        "from_revision": {"type": "integer", "minimum": 1},
        "to_revision": {"type": "integer", "minimum": 2},
        "failure_root_cause": {"type": "string", "minLength": 1},
        "invalidated_prompt_ids": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
