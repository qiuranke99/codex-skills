{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Visual Director Rule Candidate",
  "type": "object",
  "required": [
    "candidate_rule_id",
    "created_from_events",
    "failure_code",
    "hypothesis",
    "proposed_rule_text",
    "target_file",
    "applies_when",
    "counterexample_risk",
    "regression_case",
    "promotion_status"
  ],
  "properties": {
    "candidate_rule_id": {"type": "string", "minLength": 1},
    "created_from_events": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "uniqueItems": true
    },
    "failure_code": {
      "enum": [
        "route_misclass",
        "duration_defaulted",
        "escalation_trigger_missed",
        "reference_role_conflict",
        "insufficient_camera_variety",
        "weak_attention_order",
        "missing_depth_layers",
        "unmotivated_movement",
        "generic_premium_language",
        "scale_unproven",
        "photoreal_drift",
        "anime_manga_drift",
        "readable_text",
        "panel_separation_failure",
        "identity_drift",
        "product_identity_mismatch",
        "wrong_camera_angle",
        "repeated_centered_composition",
        "static_panel_dump",
        "missing_first_last_frame",
        "segment_continuity_break",
        "motion_not_motivated",
        "other"
      ]
    },
    "hypothesis": {"type": "string", "minLength": 1},
    "proposed_rule_text": {"type": "string", "minLength": 1},
    "target_file": {
      "enum": [
        "SKILL.md",
        "references/director_kernel.md",
        "references/world_class_tvc_principles.md",
        "references/shot_spec_template.md",
        "references/blue_gray_previs_style_bible.md",
        "references/observer_protocol.md",
        "scripts/route_project.py",
        "scripts/validate_shot_plan.py",
        "schemas",
        "other"
      ]
    },
    "applies_when": {"type": "string", "minLength": 1},
    "counterexample_risk": {"type": "string", "minLength": 1},
    "regression_case": {"type": "string", "minLength": 1},
    "promotion_status": {
      "enum": ["proposed", "accepted", "rejected"]
    }
  },
  "additionalProperties": false
}
