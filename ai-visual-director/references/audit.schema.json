{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Visual Director Audit",
  "type": "object",
  "required": [
    "project_id",
    "stage",
    "review_round",
    "independent_review_count",
    "adversarial_review_done",
    "dimensions"
  ],
  "properties": {
    "project_id": {"type": "string"},
    "stage": {
      "enum": ["route", "shot_plan", "storyboard_prompt", "post_image", "video_prompt", "final"]
    },
    "review_round": {"type": "integer", "minimum": 1},
    "independent_review_count": {"type": "integer", "minimum": 0},
    "adversarial_review_done": {"type": "boolean"},
    "blockers": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "dimensions": {
      "type": "object",
      "required": [
        "brief_alignment",
        "reference_role_accuracy",
        "route_decision_logic",
        "dramatic_arc",
        "shot_language_variety",
        "continuity_control",
        "storyboard_prompt_quality",
        "video_prompt_motion_design",
        "visual_qc",
        "commercial_risk_control"
      ],
      "additionalProperties": {
        "type": "object",
        "required": ["score", "evidence"],
        "properties": {
          "score": {"type": "number", "minimum": 0, "maximum": 5},
          "evidence": {"type": "string"},
          "revision_required": {"type": "boolean", "default": false}
        },
        "additionalProperties": false
      }
    },
    "review_notes": {"type": "array", "items": {"type": "string"}, "default": []}
  },
  "additionalProperties": false
}
