{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Visual Director Shot Plan",
  "type": "object",
  "required": [
    "project_title",
    "project_type",
    "duration_seconds",
    "storyboard_sheet_count",
    "video_segment_count",
    "story_engine",
    "continuity_locks",
    "sheets"
  ],
  "properties": {
    "project_title": {"type": "string"},
    "project_type": {"type": "string"},
    "duration_seconds": {"type": "number"},
    "storyboard_sheet_count": {"type": "integer", "minimum": 1},
    "panel_count": {"type": "integer", "minimum": 9},
    "video_segment_count": {"type": "integer", "minimum": 1},
    "visual_strategy": {"type": "string"},
    "story_engine": {
      "type": "object",
      "required": [
        "advertising_logline",
        "world_rule",
        "dramatic_question",
        "dramatic_arc",
        "product_role",
        "reference_synthesis",
        "duration_design",
        "motion_language",
        "anti_plastic_rules"
      ],
      "properties": {
        "advertising_logline": {"type": "string"},
        "world_rule": {"type": "string"},
        "dramatic_question": {"type": "string"},
        "dramatic_arc": {"type": "array", "items": {"type": "string"}, "minItems": 3},
        "product_role": {"type": "string"},
        "reference_synthesis": {"type": "string"},
        "duration_design": {"type": "string"},
        "motion_language": {"type": "string"},
        "anti_plastic_rules": {"type": "string"}
      },
      "additionalProperties": false
    },
    "product_visibility_rhythm": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Per-shot product visibility rhythm, for example SH_001 not_visible -> SH_002 detail_only -> SH_003 partial_visible."
    },
    "creative_concept": {
      "type": "object",
      "required": [
        "big_idea",
        "audience_desire",
        "story_tension",
        "world_rule",
        "visual_mechanism",
        "scene_ladder",
        "signature_images"
      ],
      "properties": {
        "big_idea": {"type": "string"},
        "audience_desire": {"type": "string"},
        "story_tension": {"type": "string"},
        "world_rule": {"type": "string"},
        "visual_mechanism": {"type": "string"},
        "scene_ladder": {"type": "array", "items": {"type": "string"}, "minItems": 3},
        "signature_images": {"type": "array", "items": {"type": "string"}, "minItems": 3}
      },
      "additionalProperties": false
    },
    "continuity_locks": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "product_identity_lock": {
      "type": "object",
      "required": [
        "source_reference",
        "product_name_text",
        "primary_label_text",
        "surface_text_inventory",
        "embossed_or_relief_marks",
        "label_layout",
        "packaging_shape",
        "physical_component_inventory",
        "color_material_marks",
        "required_visible_marks",
        "forbidden_changes",
        "forbidden_visual_additions",
        "full_view_fidelity_rule"
      ],
      "properties": {
        "source_reference": {"type": "string"},
        "product_name_text": {"type": "string"},
        "primary_label_text": {"type": "array", "items": {"type": "string"}},
        "surface_text_inventory": {"type": "array", "items": {"type": "string"}},
        "embossed_or_relief_marks": {"type": "array", "items": {"type": "string"}},
        "label_layout": {"type": "string"},
        "packaging_shape": {"type": "string"},
        "physical_component_inventory": {"type": "array", "items": {"type": "string"}},
        "color_material_marks": {"type": "string"},
        "required_visible_marks": {"type": "array", "items": {"type": "string"}},
        "forbidden_changes": {"type": "array", "items": {"type": "string"}},
        "forbidden_visual_additions": {"type": "array", "items": {"type": "string"}},
        "full_view_fidelity_rule": {"type": "string"}
      },
      "additionalProperties": false
    },
    "reference_roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["image", "role"],
        "properties": {
          "image": {"type": "string"},
          "role": {"type": "string"},
          "must_preserve": {"type": "array", "items": {"type": "string"}},
          "may_ignore": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "sheets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sheet_id", "time_range", "beat", "shots"],
        "properties": {
          "sheet_id": {"type": "string"},
          "time_range": {"type": "string"},
          "beat": {"type": "string"},
          "shots": {
            "type": "array",
            "minItems": 9,
            "maxItems": 9,
            "items": {
              "type": "object",
              "required": [
                "shot_id",
                "aspect_ratio",
                "scene",
                "arc_position",
                "story_beat",
                "duration",
                "shot_purpose",
                "shot_size",
                "camera_angle",
                "lens_feel",
                "camera_movement",
                "camera_motivation",
                "motion_continuity",
                "material_truth",
                "cut_logic",
                "attention_order",
                "eye_trace",
                "depth_strategy",
                "reference_parity",
                "main_subject",
                "main_action",
                "body_pose",
                "composition",
                "foreground",
                "midground",
                "background",
                "scale_reference",
                "continuity_lock",
                "must_preserve",
                "avoid"
              ],
              "properties": {
                "shot_id": {"type": "string"},
                "aspect_ratio": {"type": "string"},
                "scene": {"type": "string"},
                "arc_position": {"type": "string"},
                "story_beat": {"type": "string"},
                "scene_arena": {"type": "string"},
                "scene_role": {"type": "string"},
                "dramatic_event": {"type": "string"},
                "visual_mechanism": {"type": "string"},
                "duration": {"type": "string"},
                "shot_purpose": {"type": "string"},
                "shot_size": {"type": "string"},
                "camera_angle": {"type": "string"},
                "lens_feel": {"type": "string"},
                "camera_movement": {"type": "string"},
                "camera_motivation": {"type": "string"},
                "motion_continuity": {"type": "string"},
                "material_truth": {"type": "string"},
                "cut_logic": {"type": "string"},
                "attention_order": {"type": "string"},
                "eye_trace": {"type": "string"},
                "depth_strategy": {"type": "string"},
                "reference_parity": {"type": "string"},
                "main_subject": {"type": "string"},
                "main_action": {"type": "string"},
                "body_pose": {"type": "string"},
                "composition": {"type": "string"},
                "foreground": {"type": "string"},
                "midground": {"type": "string"},
                "background": {"type": "string"},
                "scale_reference": {"type": "string"},
                "continuity_lock": {"type": "string"},
                "product_visibility": {
                  "type": "string",
                  "enum": ["full_visible", "partial_visible", "detail_only", "not_visible"]
                },
                "product_identity_action": {"type": "string"},
                "visible_product_text_or_marks": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "array", "items": {"type": "string"}}
                  ]
                },
                "product_visual_facts": {"type": "string"},
                "forbidden_visual_additions": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "array", "items": {"type": "string"}}
                  ]
                },
                "must_preserve": {"type": "string"},
                "avoid": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
