{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Visual Director Shot Plan",
  "type": "object",
  "required": [
    "project_title",
    "project_type",
    "duration_seconds",
    "requested_video_aspect_ratio",
    "storyboard_sheet_count",
    "video_segment_count",
    "panel_count",
    "panels_per_sheet",
    "grid_layouts",
    "shots_per_video_segment",
    "agent_activation_ledger",
    "creative_concept_candidates",
    "reference_deconstruction",
    "concept_council",
    "timecoded_script_map",
    "director_script_approval",
    "storyboard_layout_decision",
    "story_engine",
    "continuity_locks",
    "sheets"
  ],
  "properties": {
    "project_title": {"type": "string"},
    "project_type": {"type": "string"},
    "duration_seconds": {"type": "number"},
    "requested_video_aspect_ratio": {
      "type": "string",
      "description": "The requested final video frame ratio, for example 9:16. Every storyboard panel/cell must match this ratio even when the overall sheet canvas uses another ratio."
    },
    "storyboard_sheet_count": {"type": "integer", "minimum": 1},
    "storyboard_grid_mode": {"type": "string"},
    "panel_count": {"type": "integer", "minimum": 1},
    "panels_per_sheet": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1},
      "minItems": 1
    },
    "grid_layouts": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "shots_per_video_segment": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1},
      "minItems": 1
    },
    "video_segment_count": {"type": "integer", "minimum": 1},
    "visual_strategy": {"type": "string"},
    "agent_activation_ledger": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "agent_role",
          "stage",
          "started_at",
          "input_evidence",
          "output_evidence",
          "decision_summary",
          "status",
          "blocks_next_stage_until"
        ],
        "properties": {
          "agent_role": {
            "enum": [
              "creative_director_agent",
              "director_agent",
              "screenwriter_agent",
              "art_director_agent"
            ]
          },
          "stage": {"type": "string"},
          "started_at": {"type": "string"},
          "input_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "output_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "decision_summary": {"type": "string"},
          "status": {"enum": ["completed"]},
          "blocks_next_stage_until": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "creative_concept_candidates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["concept_id", "logline", "visual_world", "reason_to_select_or_reject"],
        "properties": {
          "concept_id": {"type": "string"},
          "logline": {"type": "string"},
          "visual_world": {"type": "string"},
          "reason_to_select_or_reject": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "reference_deconstruction": {
      "type": "object",
      "required": [
        "references",
        "source_image_dna",
        "creative_translation",
        "literal_copy_risks",
        "agent_responsibility"
      ],
      "properties": {
        "references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "reference_id",
              "role",
              "observed_visual_facts",
              "transferable_principles",
              "must_not_copy_surface_elements",
              "assigned_agent_owner"
            ],
            "properties": {
              "reference_id": {"type": "string"},
              "role": {"type": "string"},
              "observed_visual_facts": {"type": "array", "items": {"type": "string"}, "minItems": 3},
              "transferable_principles": {"type": "array", "items": {"type": "string"}, "minItems": 3},
              "must_not_copy_surface_elements": {"type": "array", "items": {"type": "string"}, "minItems": 3},
              "assigned_agent_owner": {
                "enum": [
                  "creative_director_agent",
                  "art_director_agent",
                  "screenwriter_agent",
                  "director_agent"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "source_image_dna": {
          "type": "object",
          "required": [
            "composition_principles",
            "light_material_logic",
            "negative_space_strategy",
            "motion_implications"
          ],
          "properties": {
            "composition_principles": {"type": "array", "items": {"type": "string"}, "minItems": 3},
            "light_material_logic": {"type": "array", "items": {"type": "string"}, "minItems": 3},
            "negative_space_strategy": {"type": "array", "items": {"type": "string"}, "minItems": 2},
            "motion_implications": {"type": "array", "items": {"type": "string"}, "minItems": 2}
          },
          "additionalProperties": false
        },
        "creative_translation": {
          "type": "object",
          "required": ["borrow", "transform", "reject", "creative_leap", "new_mechanism"],
          "properties": {
            "borrow": {"type": "array", "items": {"type": "string"}, "minItems": 2},
            "transform": {"type": "array", "items": {"type": "string"}, "minItems": 3},
            "reject": {"type": "array", "items": {"type": "string"}, "minItems": 3},
            "creative_leap": {"type": "string"},
            "new_mechanism": {
              "type": "object",
              "required": [
                "borrowed_dna_ids",
                "transformed_into",
                "new_story_world_rule",
                "rejects_surface_copy_ids"
              ],
              "properties": {
                "borrowed_dna_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
                "transformed_into": {"type": "string"},
                "new_story_world_rule": {"type": "string"},
                "rejects_surface_copy_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1}
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "literal_copy_risks": {"type": "array", "items": {"type": "string"}, "minItems": 3},
        "agent_responsibility": {
          "type": "object",
          "required": [
            "creative_director_agent",
            "art_director_agent",
            "screenwriter_agent",
            "director_agent"
          ],
          "properties": {
            "creative_director_agent": {"type": "string"},
            "art_director_agent": {"type": "string"},
            "screenwriter_agent": {"type": "string"},
            "director_agent": {"type": "string"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "concept_council": {
      "type": "object",
      "required": ["creative_director", "director", "screenwriter", "art_director", "final_concept_decision"],
      "properties": {
        "creative_director": {"type": "string"},
        "director": {"type": "string"},
        "screenwriter": {"type": "string"},
        "art_director": {"type": "string"},
        "final_concept_decision": {"type": "string"},
        "unresolved_vetos": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "timecoded_script_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["time_range", "beat", "visual_event", "product_role", "director_intent"],
        "properties": {
          "time_range": {"type": "string"},
          "beat": {"type": "string"},
          "visual_event": {"type": "string"},
          "product_role": {"type": "string"},
          "director_intent": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "director_script_approval": {
      "type": "object",
      "required": ["approved", "rationale"],
      "properties": {
        "approved": {"type": "boolean"},
        "rationale": {"type": "string"}
      },
      "additionalProperties": false
    },
    "storyboard_layout_decision": {
      "type": "object",
      "required": ["policy", "rationale", "panel_count_source", "segment_mapping_source"],
      "properties": {
        "policy": {"type": "string"},
        "rationale": {"type": "string"},
        "panel_count_source": {"type": "string"},
        "segment_mapping_source": {"type": "string"}
      },
      "additionalProperties": false
    },
    "story_engine": {
      "type": "object",
      "required": [
        "advertising_logline",
        "world_rule",
        "dramatic_question",
        "dramatic_arc",
        "product_role",
        "reference_synthesis",
        "duration_design",
        "motion_language",
        "anti_plastic_rules"
      ],
      "properties": {
        "advertising_logline": {"type": "string"},
        "world_rule": {"type": "string"},
        "dramatic_question": {"type": "string"},
        "dramatic_arc": {"type": "array", "items": {"type": "string"}, "minItems": 3},
        "product_role": {"type": "string"},
        "reference_synthesis": {"type": "string"},
        "duration_design": {"type": "string"},
        "motion_language": {"type": "string"},
        "anti_plastic_rules": {"type": "string"}
      },
      "additionalProperties": false
    },
    "product_visibility_rhythm": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Per-shot product visibility rhythm, for example SH_001 not_visible -> SH_002 detail_only -> SH_003 partial_visible."
    },
    "creative_concept": {
      "type": "object",
      "required": [
        "big_idea",
        "audience_desire",
        "story_tension",
        "world_rule",
        "visual_mechanism",
        "scene_ladder",
        "signature_images"
      ],
      "properties": {
        "big_idea": {"type": "string"},
        "audience_desire": {"type": "string"},
        "story_tension": {"type": "string"},
        "world_rule": {"type": "string"},
        "visual_mechanism": {"type": "string"},
        "scene_ladder": {"type": "array", "items": {"type": "string"}, "minItems": 3},
        "signature_images": {"type": "array", "items": {"type": "string"}, "minItems": 3}
      },
      "additionalProperties": false
    },
    "continuity_locks": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "product_identity_lock": {
      "type": "object",
      "required": [
        "source_reference",
        "product_name_text",
        "primary_label_text",
        "surface_text_inventory",
        "embossed_or_relief_marks",
        "label_layout",
        "packaging_shape",
        "physical_component_inventory",
        "color_material_marks",
        "required_visible_marks",
        "forbidden_changes",
        "forbidden_visual_additions",
        "full_view_fidelity_rule"
      ],
      "properties": {
        "source_reference": {"type": "string"},
        "product_name_text": {"type": "string"},
        "primary_label_text": {"type": "array", "items": {"type": "string"}},
        "surface_text_inventory": {"type": "array", "items": {"type": "string"}},
        "embossed_or_relief_marks": {"type": "array", "items": {"type": "string"}},
        "label_layout": {"type": "string"},
        "packaging_shape": {"type": "string"},
        "physical_component_inventory": {"type": "array", "items": {"type": "string"}},
        "color_material_marks": {"type": "string"},
        "required_visible_marks": {"type": "array", "items": {"type": "string"}},
        "forbidden_changes": {"type": "array", "items": {"type": "string"}},
        "forbidden_visual_additions": {"type": "array", "items": {"type": "string"}},
        "full_view_fidelity_rule": {"type": "string"}
      },
      "additionalProperties": false
    },
    "reference_roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["image", "role"],
        "properties": {
          "image": {"type": "string"},
          "role": {"type": "string"},
          "must_preserve": {"type": "array", "items": {"type": "string"}},
          "may_ignore": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "sheets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sheet_id", "segment_id", "time_range", "beat", "panel_aspect_ratio", "shots"],
        "properties": {
          "sheet_id": {"type": "string"},
          "segment_id": {"type": "string"},
          "time_range": {"type": "string"},
          "beat": {"type": "string"},
          "sheet_canvas_aspect_ratio": {
            "type": "string",
            "description": "Optional overall bitmap canvas ratio; may differ from the video ratio when it helps pack vertical panels into a legible sheet."
          },
          "panel_aspect_ratio": {
            "type": "string",
            "description": "Aspect ratio for every panel/cell in this storyboard sheet. Must match requested_video_aspect_ratio."
          },
          "shots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "shot_id",
                "aspect_ratio",
                "scene",
                "arc_position",
                "story_beat",
                "duration",
                "shot_purpose",
                "shot_size",
                "camera_angle",
                "lens_feel",
                "camera_movement",
                "camera_motivation",
                "motion_continuity",
                "material_truth",
                "cut_logic",
                "attention_order",
                "eye_trace",
                "depth_strategy",
                "reference_parity",
                "reference_transform",
                "shot_function_signature",
                "main_subject",
                "main_action",
                "body_pose",
                "composition",
                "foreground",
                "midground",
                "background",
                "scale_reference",
                "continuity_lock",
                "must_preserve",
                "avoid"
              ],
              "properties": {
                "shot_id": {"type": "string"},
                "aspect_ratio": {"type": "string"},
                "scene": {"type": "string"},
                "arc_position": {"type": "string"},
                "story_beat": {"type": "string"},
                "scene_arena": {"type": "string"},
                "scene_role": {"type": "string"},
                "dramatic_event": {"type": "string"},
                "visual_mechanism": {"type": "string"},
                "duration": {"type": "string"},
                "shot_purpose": {"type": "string"},
                "shot_size": {"type": "string"},
                "camera_angle": {"type": "string"},
                "lens_feel": {"type": "string"},
                "camera_movement": {"type": "string"},
                "camera_motivation": {"type": "string"},
                "motion_continuity": {"type": "string"},
                "material_truth": {"type": "string"},
                "cut_logic": {"type": "string"},
                "attention_order": {"type": "string"},
                "eye_trace": {"type": "string"},
                "depth_strategy": {"type": "string"},
                "reference_parity": {"type": "string"},
                "reference_transform": {"type": "string"},
                "shot_function_signature": {
                  "type": "object",
                  "required": [
                    "information_delta",
                    "desire_delta",
                    "product_role_delta",
                    "event_type",
                    "camera_relation_key",
                    "reference_transform_id",
                    "redundancy_risk"
                  ],
                  "properties": {
                    "information_delta": {"type": "string"},
                    "desire_delta": {"type": "string"},
                    "product_role_delta": {"type": "string"},
                    "event_type": {"type": "string"},
                    "camera_relation_key": {"type": "string"},
                    "reference_transform_id": {"type": "string"},
                    "redundancy_risk": {"type": "string"}
                  },
                  "additionalProperties": false
                },
                "main_subject": {"type": "string"},
                "main_action": {"type": "string"},
                "body_pose": {"type": "string"},
                "composition": {"type": "string"},
                "foreground": {"type": "string"},
                "midground": {"type": "string"},
                "background": {"type": "string"},
                "scale_reference": {"type": "string"},
                "continuity_lock": {"type": "string"},
                "product_visibility": {
                  "type": "string",
                  "enum": ["full_visible", "partial_visible", "detail_only", "not_visible"]
                },
                "product_identity_action": {"type": "string"},
                "visible_product_text_or_marks": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "array", "items": {"type": "string"}}
                  ]
                },
                "product_visual_facts": {"type": "string"},
                "forbidden_visual_additions": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "array", "items": {"type": "string"}}
                  ]
                },
                "must_preserve": {"type": "string"},
                "avoid": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
