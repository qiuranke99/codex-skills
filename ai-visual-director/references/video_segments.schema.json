{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Google Omni Video Segments",
  "type": "object",
  "required": ["segments"],
  "properties": {
    "required_reference_setup": {
      "type": "object",
      "required": ["product_identity_reference", "product_identity_role"],
      "properties": {
        "product_identity_reference": {"type": "string"},
        "product_identity_role": {"type": "string"},
        "non_identity_references": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "product_identity_lock": {
      "type": "object",
      "required": [
        "source_reference",
        "product_name_text",
        "primary_label_text",
        "surface_text_inventory",
        "embossed_or_relief_marks",
        "label_layout",
        "packaging_shape",
        "physical_component_inventory",
        "color_material_marks",
        "required_visible_marks",
        "forbidden_changes",
        "forbidden_visual_additions",
        "full_view_fidelity_rule"
      ],
      "properties": {
        "source_reference": {"type": "string"},
        "product_name_text": {"type": "string"},
        "primary_label_text": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "surface_text_inventory": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "embossed_or_relief_marks": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "label_layout": {"type": "string"},
        "packaging_shape": {"type": "string"},
        "physical_component_inventory": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "color_material_marks": {"type": "string"},
        "required_visible_marks": {
          "type": "array",
          "items": {"type": "string"}
        },
        "forbidden_changes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "forbidden_visual_additions": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "full_view_fidelity_rule": {"type": "string"},
        "rigid_body_rule": {"type": "string"},
        "allowed_angles_or_views": {
          "type": "array",
          "items": {"type": "string"}
        },
        "forbidden_product_motion": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "global_negative_constraints": {"type": "string"},
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "segment_id",
          "time_range",
          "purpose",
          "source_shots",
          "first_frame",
          "last_frame",
          "camera_plan",
          "subject_motion",
          "environment_motion",
          "continuity_lock",
          "visual_style",
          "negative_constraints"
        ],
        "properties": {
          "segment_id": {"type": "string"},
          "time_range": {"type": "string"},
          "purpose": {"type": "string"},
          "source_shots": {"type": "array", "items": {"type": "string"}},
          "product_visibility": {
            "enum": ["full_visible", "partial_visible", "detail_only", "not_visible"]
          },
          "product_identity_reference": {"type": "string"},
          "product_motion_rule": {"type": "string"},
          "visible_product_text_or_marks": {
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}}
            ]
          },
          "product_visual_facts": {"type": "string"},
          "forbidden_visual_additions": {
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}}
            ]
          },
          "first_frame": {"type": "string"},
          "last_frame": {"type": "string"},
          "camera_plan": {"type": "string"},
          "subject_motion": {"type": "string"},
          "environment_motion": {"type": "string"},
          "continuity_lock": {"type": "string"},
          "visual_style": {"type": "string"},
          "negative_constraints": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
