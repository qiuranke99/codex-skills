{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Google Omni Video Segments",
  "type": "object",
  "required": ["requested_video_aspect_ratio", "video_story", "agent_activation_ledger", "segments"],
  "properties": {
    "requested_video_aspect_ratio": {
      "type": "string",
      "description": "Final video frame ratio, for example 9:16. Every segment prompt must preserve this frame orientation."
    },
    "agent_activation_ledger": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "agent_role",
          "stage",
          "started_at",
          "input_evidence",
          "output_evidence",
          "decision_summary",
          "status",
          "blocks_next_stage_until"
        ],
        "properties": {
          "agent_role": {
            "enum": ["director_agent", "google_omni_prompt_expert_agent"]
          },
          "stage": {"type": "string"},
          "started_at": {"type": "string"},
          "input_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "output_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "decision_summary": {"type": "string"},
          "status": {"enum": ["completed"]},
          "blocks_next_stage_until": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "video_story": {
      "type": "object",
      "required": [
        "logline",
        "story_arc",
        "world_rule",
        "emotional_turn",
        "duration_strategy",
        "anti_plastic_strategy"
      ],
      "properties": {
        "logline": {"type": "string"},
        "story_arc": {"type": "array", "items": {"type": "string"}, "minItems": 2},
        "world_rule": {"type": "string"},
        "emotional_turn": {"type": "string"},
        "duration_strategy": {"type": "string"},
        "anti_plastic_strategy": {"type": "string"}
      },
      "additionalProperties": false
    },
    "required_reference_setup": {
      "type": "object",
      "required": ["product_identity_reference", "product_identity_role"],
      "properties": {
        "product_identity_reference": {"type": "string"},
        "product_identity_role": {"type": "string"},
        "non_identity_references": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "product_identity_lock": {
      "type": "object",
      "required": [
        "source_reference",
        "product_name_text",
        "primary_label_text",
        "surface_text_inventory",
        "embossed_or_relief_marks",
        "label_layout",
        "packaging_shape",
        "physical_component_inventory",
        "color_material_marks",
        "required_visible_marks",
        "forbidden_changes",
        "forbidden_visual_additions",
        "full_view_fidelity_rule"
      ],
      "properties": {
        "source_reference": {"type": "string"},
        "product_name_text": {"type": "string"},
        "primary_label_text": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "surface_text_inventory": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "embossed_or_relief_marks": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "label_layout": {"type": "string"},
        "packaging_shape": {"type": "string"},
        "physical_component_inventory": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "color_material_marks": {"type": "string"},
        "required_visible_marks": {
          "type": "array",
          "items": {"type": "string"}
        },
        "forbidden_changes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "forbidden_visual_additions": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "full_view_fidelity_rule": {"type": "string"},
        "rigid_body_rule": {"type": "string"},
        "allowed_angles_or_views": {
          "type": "array",
          "items": {"type": "string"}
        },
        "forbidden_product_motion": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "global_negative_constraints": {"type": "string"},
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "segment_id",
          "time_range",
          "purpose",
          "aspect_ratio",
          "source_shots",
          "first_frame",
          "last_frame",
          "story_beats",
          "camera_plan",
          "lens_progression",
          "transition_grammar",
          "edit_bridge",
          "motivated_camera_path",
          "cut_strategy",
          "subject_motion",
          "environment_motion",
          "motion_continuity",
          "continuity_lock",
          "visual_style",
          "anti_plastic_constraints",
          "omni_prompt",
          "negative_constraints"
        ],
        "properties": {
          "segment_id": {"type": "string"},
          "time_range": {"type": "string"},
          "purpose": {"type": "string"},
          "aspect_ratio": {"type": "string"},
          "source_shots": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          },
          "internal_shots": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "shot_id",
                "time_span",
                "camera_state",
                "transition",
                "transition_grammar",
                "edit_bridge",
                "lens_progression_role",
                "shot_to_shot_causality",
                "motion_continuity",
                "purpose"
              ],
              "properties": {
                "shot_id": {"type": "string"},
                "time_span": {"type": "string"},
                "camera_state": {"type": "string"},
                "transition": {"type": "string"},
                "transition_grammar": {"type": "string"},
                "edit_bridge": {"type": "string"},
                "lens_progression_role": {"type": "string"},
                "shot_to_shot_causality": {"type": "string"},
                "motion_continuity": {"type": "string"},
                "purpose": {"type": "string"}
              },
              "additionalProperties": false
            }
          },
          "product_visibility": {
            "enum": ["full_visible", "partial_visible", "detail_only", "not_visible"]
          },
          "product_identity_reference": {"type": "string"},
          "product_motion_rule": {"type": "string"},
          "visible_product_text_or_marks": {
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}}
            ]
          },
          "product_visual_facts": {"type": "string"},
          "forbidden_visual_additions": {
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}}
            ]
          },
          "first_frame": {"type": "string"},
          "last_frame": {"type": "string"},
          "story_beats": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          },
          "camera_plan": {"type": "string"},
          "lens_progression": {"type": "string"},
          "transition_grammar": {"type": "string"},
          "edit_bridge": {"type": "string"},
          "motivated_camera_path": {"type": "string"},
          "cut_strategy": {"type": "string"},
          "subject_motion": {"type": "string"},
          "environment_motion": {"type": "string"},
          "motion_continuity": {"type": "string"},
          "continuity_lock": {"type": "string"},
          "visual_style": {"type": "string"},
          "anti_plastic_constraints": {"type": "string"},
          "omni_prompt": {"type": "string"},
          "negative_constraints": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
