{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Visual Director Intake",
  "type": "object",
  "required": ["brief"],
  "properties": {
    "brief": {
      "type": "string",
      "minLength": 1
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 1
    },
    "video_segment_seconds": {
      "type": "number",
      "minimum": 1,
      "default": 10
    },
    "reference_images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {"type": "string"},
          "role_hint": {"type": "string"},
          "must_preserve": {"type": "array", "items": {"type": "string"}},
          "may_ignore": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      },
      "default": []
    },
    "output_targets": {
      "type": "array",
      "items": {
        "enum": ["storyboard_sheets", "image_prompts", "google_omni_prompts", "qc_report"]
      },
      "default": ["storyboard_sheets", "google_omni_prompts", "qc_report"]
    },
    "production_mode": {
      "enum": ["standard_fast", "rush", "premium_pitch", "certification"],
      "default": "standard_fast"
    },
    "observer_mode": {
      "enum": ["auto", "off", "full"],
      "default": "auto"
    },
    "conflicting_reference_roles": {
      "type": "boolean",
      "default": false
    },
    "advanced_cinematic_language": {
      "type": "boolean",
      "default": false
    },
    "complex_delivery_mode": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
