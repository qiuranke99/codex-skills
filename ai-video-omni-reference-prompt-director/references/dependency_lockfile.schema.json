{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dependency_lockfile.schema.json",
  "title": "AI Video Prompt Dependency Lockfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version", "artifact_id", "owner_skill", "version", "sha256",
    "approval_status", "dependencies", "affected_shot_uids", "stale_reason",
    "schema_version", "project_id", "package_id", "input_locks", "output_locks"
  ],
  "properties": {
    "contract_version": {"const": "ai-video-artifact-v1"},
    "artifact_id": {"type": "string"}, "owner_skill": {"const": "ai-video-omni-reference-prompt-director"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "approval_status": {"enum": ["draft", "assistant_validated", "user_approved", "stale", "blocked"]},
    "dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependency"}},
    "affected_shot_uids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "stale_reason": {"type": ["string", "null"]},
    "schema_version": {"const": "ai-video-dependency-lockfile.v1"},
    "project_id": {"type": "string"}, "package_id": {"type": "string"},
    "input_locks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/inputLock"}},
    "output_locks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/outputLock"}}
  },
  "$defs": {
    "dependency": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "owner_skill", "version", "sha256"],
      "properties": {
        "artifact_id": {"type": "string"}, "owner_skill": {"type": "string"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "inputLock": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "owner_skill", "version", "sha256", "file_path", "file_sha256", "artifact_record_locator", "artifact_record_file_sha256"],
      "properties": {
        "artifact_id": {"type": "string"}, "owner_skill": {"type": "string"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "file_path": {"type": ["string", "null"]},
        "file_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "artifact_record_locator": {"type": "string", "minLength": 1, "not": {"pattern": "(^/|(^|/)\\.\\.(/|$))"}},
        "artifact_record_file_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "outputLock": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "version", "file_path", "file_sha256", "depends_on_artifact_ids"],
      "properties": {
        "artifact_id": {"type": "string"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "file_path": {"type": "string"},
        "file_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "depends_on_artifact_ids": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
