{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reference_atlas_spec.schema.json",
  "title": "Deterministic Reference Atlas Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "atlas_id", "generation_unit_id", "layout_columns", "background_rgb",
    "minimum_panel_width_pixels", "minimum_panel_height_pixels", "legibility_policy",
    "source_decode_policy", "output_encode_policy", "layout_policy", "output_codec", "sources"
  ],
  "properties": {
    "schema_version": {"const": "ai-video-deterministic-atlas-spec.v2"},
    "atlas_id": {"type": "string", "minLength": 1},
    "generation_unit_id": {"type": "string", "minLength": 1},
    "layout_columns": {"type": "integer", "minimum": 1},
    "background_rgb": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {"type": "integer", "minimum": 0, "maximum": 255}
    },
    "minimum_panel_width_pixels": {"type": "integer", "minimum": 256},
    "minimum_panel_height_pixels": {"type": "integer", "minimum": 256},
    "legibility_policy": {"const": "identity_geometry_look_only_no_microcopy"},
    "source_decode_policy": {"const": "pillow_common_raster_to_rgb8_no_resize_v1"},
    "output_encode_policy": {"const": "pillow_png_rgb8_fixed_v1"},
    "layout_policy": {"const": "max_native_cell_center_floor_no_resize_v1"},
    "output_codec": {"const": "PNG_RGB8"},
    "sources": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["artifact_id", "file_path", "file_sha256", "control_roles", "control_role"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "file_path": {"type": "string", "minLength": 1, "not": {"pattern": "(^/|(^|/)\\.\\.(/|$))"}},
          "file_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "control_roles": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {
              "enum": [
                "identity", "wardrobe", "product_geometry", "material_behavior", "scene_canon",
                "global_look", "storyboard", "keyframe_state", "keyframe_boundary"
              ]
            }
          },
          "control_role": {
            "enum": [
              "identity", "wardrobe", "product_geometry", "material_behavior", "scene_canon",
              "global_look", "storyboard", "keyframe_state", "keyframe_boundary"
            ]
          }
        }
      }
    }
  }
}
