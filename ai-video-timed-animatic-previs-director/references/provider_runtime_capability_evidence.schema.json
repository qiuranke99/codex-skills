{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/ai-video-timed-animatic-previs-director/provider_runtime_capability_evidence.schema.json",
  "title": "Provider Runtime Capability Evidence Projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "profile_id", "provider", "model_family", "model_id", "surface",
    "documented_backend_profile_id", "generation_mode", "surface_status",
    "supported_modalities", "effective_limits", "video_input_constraints"
  ],
  "properties": {
    "schema_version": {"const": "provider-runtime-capability-evidence.v1"},
    "profile_id": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "model_family": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "surface": {"type": "string", "minLength": 1},
    "documented_backend_profile_id": {"type": "string", "minLength": 1},
    "generation_mode": {"const": "omni_reference_to_video"},
    "surface_status": {"const": "provider_schema_verified"},
    "supported_modalities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["text", "image", "video", "audio"]},
      "contains": {"const": "video"}
    },
    "effective_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_duration_seconds", "max_image_inputs", "max_video_inputs", "max_audio_inputs", "max_total_multimodal_inputs"],
      "properties": {
        "max_duration_seconds": {"type": "number", "exclusiveMinimum": 0},
        "max_image_inputs": {"type": "integer", "minimum": 0},
        "max_video_inputs": {"type": "integer", "minimum": 1},
        "max_audio_inputs": {"type": "integer", "minimum": 0},
        "max_total_multimodal_inputs": {"type": "integer", "minimum": 1}
      }
    },
    "video_input_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted_media_types", "accepted_containers", "accepted_video_codecs",
        "max_file_bytes", "min_duration_seconds", "max_duration_seconds",
        "min_width_px", "max_width_px", "min_height_px", "max_height_px",
        "min_aspect_ratio", "max_aspect_ratio", "min_fps", "max_fps",
        "audio_track_policy"
      ],
      "properties": {
        "accepted_media_types": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "accepted_containers": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "accepted_video_codecs": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "max_file_bytes": {"type": "integer", "minimum": 1},
        "min_duration_seconds": {"type": "number", "exclusiveMinimum": 0},
        "max_duration_seconds": {"type": "number", "exclusiveMinimum": 0},
        "min_width_px": {"type": "integer", "minimum": 1},
        "max_width_px": {"type": "integer", "minimum": 1},
        "min_height_px": {"type": "integer", "minimum": 1},
        "max_height_px": {"type": "integer", "minimum": 1},
        "min_aspect_ratio": {"type": "number", "exclusiveMinimum": 0},
        "max_aspect_ratio": {"type": "number", "exclusiveMinimum": 0},
        "min_fps": {"type": "number", "exclusiveMinimum": 0},
        "max_fps": {"type": "number", "exclusiveMinimum": 0},
        "audio_track_policy": {"enum": ["forbidden", "optional", "required"]}
      }
    }
  }
}
