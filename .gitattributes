* text=auto

# Deterministic cross-platform source and contract bytes.
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.svg text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.tsv text eol=lf

# Media and source-document bytes must never be newline-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.mp4 binary
*.mov binary
*.wav binary
*.doc binary
*.docx binary
*.rtf binary
*.pdf binary
